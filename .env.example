# Админ-панель: https://ваш-сайт.ru/admin
#
# Вариант A — автосоздание первого администратора в SQLite при первом запросе к API:
#   NUXT_ADMIN_PASSWORD — пароль (хранится только как хеш в БД)
#   NUXT_ADMIN_EMAIL — логин (обязательно email), по умолчанию admin@urbantechstroy.local
NUXT_ADMIN_PASSWORD=
NUXT_ADMIN_EMAIL=

# После смены пароля/email перезапустите `npm run dev` или процесс Node — значения подтянутся в SQLite.

# Вариант B — регистрация первого администратора на странице /admin/register:
#   задайте секрет; на форме введите тот же ключ + email + пароль
NUXT_ADMIN_SETUP_KEY=

# Опционально: путь к SQLite (по умолчанию .data/site.db в корне приложения)
# NUXT_DATABASE_PATH=/var/lib/urbantechstroy/site.db

# Опционально: каталог загруженных из админки (по умолчанию .data/uploads)
# NUXT_UPLOAD_DIR=/var/lib/urbantechstroy/uploads

# Публичный URL сайта (без слэша в конце) — для превью в соцсетях (og:image, canonical)
# NUXT_PUBLIC_SITE_URL=https://ваш-домен.ru

# Опционально: свой текст для Open Graph / Twitter (по умолчанию — описание компании в коде)
# NUXT_PUBLIC_OG_DESCRIPTION=
